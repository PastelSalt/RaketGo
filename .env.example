# Preferred for Vercel/managed MySQL (Aiven, PlanetScale, Railway, etc.)
RAKETGO_DATABASE_URL=

# Alternative split configuration (used when RAKETGO_DATABASE_URL is empty)
RAKETGO_DB_HOST=localhost
RAKETGO_DB_PORT=3306
RAKETGO_DB_USER=root
RAKETGO_DB_PASS=
RAKETGO_DB_NAME=raketgo

# Enable when your MySQL host requires TLS/SSL
RAKETGO_DB_SSL=false
RAKETGO_DB_SSL_REJECT_UNAUTHORIZED=true

SESSION_SECRET=replace-with-a-very-long-random-string-at-least-32-characters
NEXT_PUBLIC_SITE_NAME=RaketGo
