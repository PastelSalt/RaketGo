# Supabase project URL + browser-safe publishable key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase server-side keys (never expose these in client-side code)
# Required by auth routes:
# - SUPABASE_ANON_KEY for login password verification
# - SUPABASE_SERVICE_ROLE_KEY for signup and legacy-account backfill
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=

# Supabase Postgres connection strings
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_HOST=
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSL=true
# Set to false when your runtime reports "self-signed certificate in certificate chain".
POSTGRES_SSL_REJECT_UNAUTHORIZED=false

# App DB fallback expected by src/lib/db.ts
DATABASE_URL=

# Legacy MySQL fallback (optional)
RAKETGO_DATABASE_URL=
RAKETGO_DB_HOST=localhost
RAKETGO_DB_PORT=3306
RAKETGO_DB_USER=root
RAKETGO_DB_PASS=
RAKETGO_DB_NAME=raketgo
RAKETGO_DB_SSL=false
RAKETGO_DB_SSL_REJECT_UNAUTHORIZED=true

SESSION_SECRET=replace-with-a-very-long-random-string-at-least-32-characters
NEXT_PUBLIC_SITE_NAME=RaketGo
